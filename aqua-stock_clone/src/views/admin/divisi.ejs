<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Manajemen Divisi</h1>
    <button class="btn btn-primary" data-toggle="modal" data-target="#modalCreate">
        <i class="fas fa-plus"></i> Tambah Divisi
    </button>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Daftar Divisi (Kategori)</h6>
        <div class="input-group" style="max-width: 250px;">
            <input id="tableSearch" class="form-control form-control-sm" placeholder="Cari ...">
            <div class="input-group-append">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="divisiTable">
                <thead class="thead-light">
                    <tr>
                        <th style="width:50px;">No</th>
                        <th>Nama Divisi</th>
                        <th>Keterangan</th>
                        <th style="width:120px;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% divisi.forEach((d, i) => { %>
                        <tr>
                            <td class="text-center"><%= i + 1 %></td>
                            <td class="font-weight-bold"><%= d.nama %></td>
                            <td><%= d.keterangan || '-' %></td>
                            <td class="text-nowrap">
                                <button type="button" class="btn btn-sm btn-info" data-toggle="modal"
                                    data-target="#modalEdit" data-id="<%= d.id %>" data-nama="<%= d.nama %>"
                                    data-keterangan="<%= d.keterangan || '' %>">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <button type="button" class="btn btn-sm btn-danger btn-del" data-id="<%= d.id %>"
                                    data-nama="<%= d.nama %>">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- CREATE MODAL -->
<div class="modal fade" id="modalCreate" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <form method="post" action="/admin/divisi" class="modal-content">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="modal-header">
                <h5 class="modal-title">Tambah Divisi</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Nama Divisi</label>
                    <input name="nama" class="form-control" required placeholder="Mis. Televisi, Elektronik">
                </div>
                <div class="form-group">
                    <label>Keterangan (Opsional)</label>
                    <textarea name="keterangan" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Batal</button>
                <button class="btn btn-primary" type="submit">Simpan</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="modalEdit" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <form id="formEdit" method="post" class="modal-content">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="modal-header">
                <h5 class="modal-title">Edit Divisi</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Nama Divisi</label>
                    <input name="nama" id="edit_nama" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Keterangan</label>
                    <textarea name="keterangan" id="edit_keterangan" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Batal</button>
                <button class="btn btn-primary" type="submit">Simpan Perubahan</button>
            </div>
        </form>
    </div>
</div>

<!-- DataTables -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/datatables.net-bs4/1.13.6/dataTables.bootstrap4.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables.net/1.13.6/jquery.dataTables.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/datatables.net-bs4/1.13.6/dataTables.bootstrap4.min.js"></script>

<script>
    $(function () {
        const dt = $('#divisiTable').DataTable({
            pageLength: 10, lengthChange: false, order: [[1, 'asc']]
        });
        $('#divisiTable_filter').hide();
        $('#tableSearch').on('keyup', function () { dt.search(this.value).draw(); });

        $('#modalEdit').on('show.bs.modal', function (e) {
            const $btn = $(e.relatedTarget).closest('button');
            const id = $btn.data('id');
            $('#formEdit').attr('action', '/admin/divisi/' + id);
            $('#edit_nama').val($btn.data('nama'));
            $('#edit_keterangan').val($btn.data('keterangan'));
        });

        $('.btn-del').on('click', function () {
            const $btn = $(this);
            const id = $btn.data('id');
            const nama = $btn.data('nama');

            Swal.fire({
                title: 'Hapus divisi?',
                html: `Divisi <b>${nama}</b> akan dihapus permanen.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, hapus',
                cancelButtonText: 'Batal',
                reverseButtons: true
            }).then((r) => {
                if (r.isConfirmed) {
                    const form = $('<form>', { method: 'post', action: '/admin/divisi/' + id + '/delete' });
                    form.append($('<input>', { type: 'hidden', name: '_csrf', value: '<%= csrfToken %>' }));
                    $('body').append(form);
                    form.trigger('submit');
                }
            });
        });

        const params = new URLSearchParams(location.search);
        const ok = params.get('ok'); const err = params.get('err');
        if (ok) {
            Swal.fire({
                toast: true, position: 'top-end', icon: 'success',
                title: ok === 'created' ? 'Divisi dibuat' : ok === 'updated' ? 'Perubahan disimpan' : 'Divisi dihapus',
                showConfirmButton: false, timer: 2200, timerProgressBar: true
            });
            params.delete('ok'); history.replaceState({}, '', location.pathname + (params.toString() ? ('?' + params.toString()) : ''));
        }
        if (err) {
            Swal.fire({ icon: 'error', title: 'Gagal', text: err });
            params.delete('err'); history.replaceState({}, '', location.pathname + (params.toString() ? ('?' + params.toString()) : ''));
        }
    });
</script>
