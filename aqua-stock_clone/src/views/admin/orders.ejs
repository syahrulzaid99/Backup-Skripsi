<div class="container-fluid">
    <style>
        /* Glassmorphism & Modern Premium Refinements */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

        .container-fluid {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .aesthetic-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04), 0 1px 3px rgba(0, 0, 0, 0.02) !important;
            transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            background: #ffffff;
            overflow: hidden;
        }

        .aesthetic-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08), 0 5px 15px rgba(0, 0, 0, 0.04) !important;
        }

        .aesthetic-header {
            background: rgba(248, 249, 252, 0.8) !important;
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.03) !important;
            padding: 1.5rem !important;
        }

        .btn-modern-danger {
            background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%);
            color: #fff;
            box-shadow: 0 4px 12px rgba(231, 74, 59, 0.3);
        }

        .btn-modern-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(231, 74, 59, 0.4);
            color: #fff;
        }

        .pill-badge {
            padding: 0.5em 1.2em !important;
            border-radius: 50rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-size: 0.75em !important;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
            color: white !important;
        }

        .badge-success {
            background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%);
        }

        .badge-info {
            background: linear-gradient(135deg, #36b9cc 0%, #258391 100%);
        }

        .badge-secondary {
            background: linear-gradient(135deg, #858796 0%, #60616f 100%);
        }

        .badge-danger {
            background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%);
        }

        .badge-warning {
            background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%);
        }

        .aesthetic-table {
            border-collapse: separate;
            border-spacing: 0;
            border: none;
        }

        .aesthetic-table thead th {
            border-bottom: 2px solid #e3e6f0;
            background: #f8f9fc;
            color: #858796;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.8px;
            padding: 12px 8px;
        }

        .aesthetic-table tbody tr {
            transition: background 0.2s;
        }

        .aesthetic-table tbody tr:hover {
            background-color: #f1f4fb;
        }

        .aesthetic-table td {
            border-top: 1px solid #f1f3f9;
            vertical-align: middle;
            padding: 10px 8px;
        }

        .kode-highlight {
            color: #4e73df;
            background: #eaecfb;
            padding: 4px 10px;
            border-radius: 6px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }

        .grand-total-row {
            background: #fafbfc;
        }

        .grand-total-text {
            font-size: 1.3em !important;
            background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900 !important;
        }
    </style>
    <div class="d-sm-flex align-items-center justify-content-between mb-4 mt-2">
        <h1 class="h3 mb-0 page-title">Pesanan Cabang</h1>
    </div>

    <% var list = Array.isArray(orders) ? orders : []; %>

    <% if (list.length === 0) { %>
        <div class="card shadow mb-4 aesthetic-card">
            <div class="card-body">
                <div class="text-center py-5">
                    <i class="fas fa-shopping-cart fa-3x text-gray-300 mb-3"></i>
                    <p class="mb-0 text-muted">Belum ada pesanan dari cabang.</p>
                </div>
            </div>
        </div>
    <% } %>

    <% for (var si = 0; si < list.length; si++) { %>
        <% 
            var o = list[si]; 
            var st = (o.status || '').toLowerCase(); 
            var cabang = (usersMap && usersMap[o.cabang_id]) ? usersMap[o.cabang_id] : null; 
            
            var badgeClass = 'badge badge-secondary'; 
            if (st === 'pending') { badgeClass = 'badge badge-warning'; } 
            if (st === 'diproses') { badgeClass = 'badge badge-info'; } 
            if (st === 'dikirim') { badgeClass = 'badge badge-primary'; } 
            if (st === 'selesai') { badgeClass = 'badge badge-success'; } 
            if (st === 'ditolak') { badgeClass = 'badge badge-danger'; } 
        %>

        <div class="card aesthetic-card mb-4">
            <div class="card-header aesthetic-header d-flex justify-content-between align-items-center">
                <div>
                    <div class="font-weight-bold mb-2">
                        Kode Order: <span class="kode-highlight"><%= o.kode_order %></span>
                    </div>
                    <div class="small text-muted mb-1" style="font-size: 0.85rem">
                        <i class="fas fa-store mr-1"></i> Cabang: <strong><%= cabang ? cabang.username : o.cabang_id %></strong>
                    </div>
                    <div class="small text-muted">
                        <i class="far fa-clock mr-1"></i> Tanggal: 
                        <strong>
                            <% if (o.createdAt) { %>
                                <% 
                                    var dateObj = new Date(o.createdAt._seconds ? o.createdAt._seconds * 1000 : o.createdAt);
                                    var formattedDate = dateObj.toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute:'2-digit'});
                                %>
                                <%= formattedDate %>
                            <% } else { %>
                                -
                            <% } %>
                        </strong>
                    </div>
                </div>
                <div class="d-flex align-items-center" style="gap:12px;">
                    <span class="<%= badgeClass %> pill-badge">
                        <%= (o.status || 'pending').toUpperCase() %>
                    </span>
                    <form method="POST" action="/admin/orders/<%= o.id %>/delete" style="display:inline;" data-confirm-delete>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Hapus Pesanan" style="font-size: 1.1rem; line-height: 1;">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="card-body px-4 py-3">
                <% if (o.keterangan) { %>
                <div class="alert alert-info py-2 px-3 mb-3" style="font-size: 0.9rem;">
                    <i class="fas fa-info-circle mr-2"></i><strong>Catatan Cabang:</strong> <%= o.keterangan %>
                </div>
                <% } %>
                <div class="table-responsive">
                    <table class="table aesthetic-table w-100 mb-2">
                        <thead class="thead-light">
                            <tr>
                                <th style="width:48px;">#</th>
                                <th>SKU</th>
                                <th>Nama Produk</th>
                                <th style="width:120px;">Satuan</th>
                                <th style="width:120px;" class="text-right">Harga</th>
                                <th style="width:120px;" class="text-right">Qty Order</th>
                                <th style="width:150px;" class="text-right">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% var grandTotal = 0; %>
                            <% var items = Array.isArray(o.items) ? o.items : []; 
                               for (var i = 0; i < items.length; i++) { 
                                   var it = items[i]; 
                                   var sub = Number(it.subtotal || 0);
                                   grandTotal += sub;
                            %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= it.sku || '-' %></td>
                                <td><%= it.nama_produk || '-' %></td>
                                <td><%= it.satuan || '-' %></td>
                                <td class="text-right">Rp <%= Number(it.harga || 0).toLocaleString('id-ID') %></td>
                                <td class="text-right font-weight-bold"><%= it.qty %></td>
                                <td class="text-right font-weight-bold" style="color: #4e73df;">
                                    Rp <%= sub.toLocaleString('id-ID') %>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                        <tfoot>
                            <tr class="grand-total-row">
                                <td colspan="6" class="text-right text-uppercase"
                                    style="font-weight: 800; color: #858796; letter-spacing: 0.5px; vertical-align: middle;">
                                    Grand Total Pesanan
                                </td>
                                <td class="text-right grand-total-text">
                                    Rp <%= grandTotal.toLocaleString('id-ID') %>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="mt-4 p-3 rounded" style="background: #f8f9fc; border: 1px solid #e3e6f0;">
                    <h6 class="font-weight-bold text-primary text-uppercase mb-3" style="font-size: 0.85rem;">
                        <i class="fas fa-edit mr-1"></i> Update Status Pesanan
                    </h6>
                    <form method="POST" action="/admin/orders/<%= o.id %>" class="form-inline" data-confirm-status>
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                        <div class="form-group mb-2 mr-3">
                            <label class="mr-2 font-weight-bold text-gray-700" style="font-size: 0.9rem;">Status</label>
                            <select name="status" class="form-control form-control-sm border-0 shadow-sm" style="min-width: 150px;">
                                <option value="pending" <%= st === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="diproses" <%= st === 'diproses' ? 'selected' : '' %>>Diproses</option>
                                <option value="dikirim" <%= st === 'dikirim' ? 'selected' : '' %>>Dikirim</option>
                                <option value="selesai" <%= st === 'selesai' ? 'selected' : '' %>>Selesai</option>
                                <option value="ditolak" <%= st === 'ditolak' ? 'selected' : '' %>>Ditolak</option>
                            </select>
                        </div>

                        <div class="form-group mb-2 mr-3 flex-grow-1">
                            <input type="text" name="keterangan"
                                class="form-control form-control-sm w-100 border-0 shadow-sm" placeholder="Catatan Admin (opsional)"
                                value="<%= o.keterangan_admin || '' %>">
                        </div>

                        <button type="submit" class="btn btn-sm btn-primary mb-2 shadow-sm px-3">
                            <i class="fas fa-save mr-1"></i> Simpan Status
                        </button>
                    </form>
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
    (function () {
        var params = new URLSearchParams(window.location.search);
        var ok = params.get('ok');
        var err = params.get('err');

        function hasSwal() { return typeof Swal !== 'undefined' && Swal && Swal.fire; }

        if (ok && hasSwal()) {
            var title = ok;
            if (ok === 'updated') title = 'Status pesanan berhasil diperbarui';
            if (ok === 'deleted') title = 'Pesanan berhasil dihapus';

            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: title, showConfirmButton: false, timer: 3000, timerProgressBar: true });
            params.delete('ok');
            var url = location.pathname + (params.toString() ? '?' + params.toString() : '');
            window.history.replaceState({}, '', url);
        }

        if (err && hasSwal()) {
            Swal.fire({ icon: 'error', title: 'Gagal', text: err });
            params.delete('err');
            var url2 = location.pathname + (params.toString() ? '?' + params.toString() : '');
            window.history.replaceState({}, '', url2);
        }

        // === KONFIRMASI UBAH STATUS (delegation)
        document.addEventListener('submit', function (ev) {
            var form = ev.target;
            if (!form || !form.matches('form[data-confirm-status]')) return;

            if (form.dataset.confirmHandled === '1') return;

            ev.preventDefault();
            var sel = form.querySelector('select[name="status"]');
            var status = sel ? sel.value : '';

            var msg = status ? ('Status pesanan akan diubah menjadi "' + status.toUpperCase() + '".') : 'Simpan perubahan status pesanan?';

            if (hasSwal()) {
                Swal.fire({
                    icon: 'question',
                    title: 'Update Status Pesanan?',
                    text: msg,
                    showCancelButton: true,
                    confirmButtonText: 'Simpan',
                    cancelButtonText: 'Batal',
                    confirmButtonColor: '#4e73df'
                }).then(function (r) {
                    if (r.isConfirmed) {
                        form.dataset.confirmHandled = '1';
                        form.submit();
                    }
                });
            } else {
                if (confirm(msg)) {
                    form.dataset.confirmHandled = '1';
                    form.submit();
                }
            }
        }, true);

        // === KONFIRMASI HAPUS PESANAN
        document.addEventListener('submit', function (ev) {
            var form = ev.target;
            if (!form || !form.matches('form[data-confirm-delete]')) return;

            if (form.dataset.confirmHandled === '1') return;

            ev.preventDefault();

            var msg = 'Apakah Anda yakin ingin menghapus pesanan ini? Tindakan ini tidak dapat dibatalkan.';

            if (hasSwal()) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Hapus Pesanan?',
                    text: msg,
                    showCancelButton: true,
                    confirmButtonText: 'Ya, Hapus',
                    cancelButtonText: 'Batal',
                    confirmButtonColor: '#e74a3b'
                }).then(function (r) {
                    if (r.isConfirmed) {
                        form.dataset.confirmHandled = '1';
                        form.submit();
                    }
                });
            } else {
                if (confirm(msg)) {
                    form.dataset.confirmHandled = '1';
                    form.submit();
                }
            }
        }, true);
    })();
</script>
