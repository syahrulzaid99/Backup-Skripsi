<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/css/sb-admin-2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background: #4e73df;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
        }
        .login-card {
            border: none;
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            box-shadow: 0 25px 60px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.6);
            overflow: hidden;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .login-card:hover {
            transform: translateY(-5px);
        }
        .form-control-user {
            border-radius: 14px !important;
            padding: 1.5rem 1.25rem !important;
            font-size: 1.05rem !important;
            border: 2px solid #eaecfb !important;
            transition: all 0.3s ease !important;
            background: #f8f9fc !important;
        }
        .form-control-user:focus {
            border-color: #4e73df !important;
            background: #ffffff !important;
            box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.15) !important;
        }
        .btn-login {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
            border: none;
            border-radius: 14px !important;
            padding: 1rem !important;
            font-size: 1.15rem !important;
            font-weight: 700 !important;
            letter-spacing: 1px;
            box-shadow: 0 6px 20px rgba(78, 115, 223, 0.4) !important;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        }
        .btn-login:hover {
            transform: translateY(-3px) !important;
            box-shadow: 0 10px 25px rgba(78, 115, 223, 0.5) !important;
        }
        .title-brand {
            font-weight: 900;
            color: #4e73df;
            font-size: 2.8rem;
            letter-spacing: -1.5px;
            margin-bottom: 5px;
            text-shadow: 0px 4px 10px rgba(0,0,0,0.05);
        }
        .input-icon-wrap {
            position: relative;
        }
        .input-icon-wrap i {
            position: absolute;
            top: 50%;
            left: 20px;
            transform: translateY(-50%);
            color: #b7b9cc;
            font-size: 1.1rem;
            transition: 0.3s;
        }
        .input-icon-wrap input {
            padding-left: 55px !important;
        }
        .input-icon-wrap input:focus + i {
            color: #4e73df;
        }
    </style>
</head>

<body>
    <div class="container w-100">
        <div class="row justify-content-center align-items-center">
            <div class="col-xl-5 col-lg-6 col-md-8">
                <div class="card login-card my-5">
                    <div class="card-body p-sm-5 p-4">
                        <div class="text-center mb-5">
                            <h1 class="title-brand">Aqua Stock</h1>
                            <p class="text-muted m-0" style="font-weight: 500; font-size: 1.1rem;">Sistem Manajemen Logistik</p>
                        </div>

                        <form class="user" method="post" action="/login">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="form-group mb-4 position-relative">
                                <div class="input-icon-wrap">
                                    <input name="username" id="username" class="form-control form-control-user" placeholder="Nama Pengguna" value="<%= typeof oldUsername !== 'undefined' && oldUsername ? oldUsername : '' %>" required autocomplete="off">
                                    <i class="fas fa-user"></i>
                                </div>
                            </div>
                            <div class="form-group mb-5 position-relative">
                                <div class="input-icon-wrap">
                                    <input name="password" id="password" type="password" class="form-control form-control-user" placeholder="Kata Sandi" required>
                                    <i class="fas fa-lock"></i>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-user btn-block btn-login text-white">
                                MASUK SISTEM
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/startbootstrap-sb-admin-2/4.1.4/js/sb-admin-2.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var err = "<%= typeof error !== 'undefined' ? error : '' %>";
            
            if (err === 'invalid') {
                Swal.fire({
                    icon: 'error',
                    title: 'Login Gagal',
                    text: 'Username atau password salah!',
                    confirmButtonText: 'Coba Lagi'
                }).then(() => {
                    document.getElementById('password').value = '';
                    document.getElementById('password').focus();
                });
            } else if (err === 'empty') {
                Swal.fire({
                    icon: 'warning',
                    title: 'Input Kosong',
                    text: 'Silakan isi username dan password.',
                    confirmButtonText: 'Oke'
                }).then(() => {
                    var u = document.getElementById('username');
                    if(!u.value) u.focus();
                    else document.getElementById('password').focus();
                });
            } else {
                var u = document.getElementById('username');
                if(!u.value) u.focus();
                else document.getElementById('password').focus();
            }
        });
    </script>
</body>

</html>